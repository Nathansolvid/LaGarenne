{
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "framework": null,
  "redirects": [
    { "source": "/pension-chevaux", "destination": "https://ecuries.domainedegarenne.com/pension.html", "permanent": true },
    { "source": "/pension-chevaux/", "destination": "https://ecuries.domainedegarenne.com/pension.html", "permanent": true },
    { "source": "/ecuries", "destination": "https://ecuries.domainedegarenne.com/", "permanent": true },
    { "source": "/ecuries/", "destination": "https://ecuries.domainedegarenne.com/", "permanent": true },
    { "source": "/les-gites", "destination": "/hebergements.html", "permanent": true },
    { "source": "/les-gites/", "destination": "/hebergements.html", "permanent": true },
    { "source": "/les-roulottes", "destination": "/hebergements.html", "permanent": true },
    { "source": "/les-roulottes/", "destination": "/hebergements.html", "permanent": true },
    { "source": "/la-peche", "destination": "/sejours.html", "permanent": true },
    { "source": "/la-peche/", "destination": "/sejours.html", "permanent": true },
    { "source": "/contact", "destination": "/contact.html", "permanent": true },
    { "source": "/contact/", "destination": "/contact.html", "permanent": true },
    { "source": "/accueil", "destination": "/", "permanent": true },
    { "source": "/accueil/", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }]
    },
    {
      "source": "/data/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
